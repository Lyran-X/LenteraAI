APP_NAME="LenteraAI API"
APP_VERSION="0.1.0"
APP_ENV="development"
API_V1_PREFIX="/api"

# Copy this from Neon Dashboard -> Project -> Connect.
# Use the direct connection string for Alembic migrations.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require"

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY="replace-with-a-long-random-secret"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60

# JSON array format is required for list parsing.
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

UPLOAD_DIR="uploads/documents"
VECTOR_STORE="chroma"
CHROMA_PERSIST_DIR="./storage/chroma"
VECTOR_COLLECTION="edupath_documents"
EMBEDDING_MODEL="local-hash-embedding-v1"

# Placeholder for RAG answer generation.
# Fill this later when you connect a real LLM provider.
LLM_PROVIDER="placeholder"
LLM_MODEL="models/gemini-2.0-flash"
LLM_API_KEY=""

# Optional LLM providers for AI Tutor.
# Keep empty for development fallback responses.
OPENAI_API_KEY=""
GEMINI_API_KEY=""
GROQ_API_KEY=""
GEMINI_MODEL="models/gemini-2.0-flash"
